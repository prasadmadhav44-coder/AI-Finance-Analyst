# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in real values. NEVER commit the actual .env file.
#
# In production (Render, Railway, etc.), set these as environment
# variables / secrets in the platform's dashboard instead of a file.

# ---------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------

# Google AI Studio / Gemini API key. Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------
# Recommended for production
# ---------------------------------------------------------------------

# "production" or "development". Controls debug mode, HSTS header, and
# strictness of config validation. Default: production
FLASK_ENV=production

# Explicit override for Flask debug mode. Default: derived from FLASK_ENV
# (false in production, true in development). Never set this to true in
# production — it exposes the interactive debugger to anyone who can
# trigger a 500 error.
FLASK_DEBUG=false

# Random secret used for session/cookie signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_value

# Comma-separated list of origins allowed to call /analyze cross-origin.
# Leave empty (default) if the frontend is served by this same Flask app,
# which is the default setup here.
ALLOWED_ORIGINS=

# ---------------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------------

# Comma-separated Gemini model fallback chain, tried in order when a model
# returns a transient error (503) or quota error (429).
MODEL_FALLBACK_CHAIN=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# Explicit override for the primary model (defaults to the first entry in
# MODEL_FALLBACK_CHAIN if unset).
PRIMARY_MODEL_ID=

# Rate limits. Syntax: "<count> per <second|minute|hour|day>"
ANALYZE_RATE_LIMIT=10 per minute
GLOBAL_RATE_LIMIT=200 per hour

# Maximum characters allowed in a single /analyze query.
MAX_QUERY_LENGTH=1000

# Maximum request body size in bytes (default 16 KB).
MAX_CONTENT_LENGTH_BYTES=16384

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
